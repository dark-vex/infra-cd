        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(node_network_receive_bytes_total{site=\"bgy\"}[$__range])) + sum(increase(node_network_transmit_bytes_total{site=\"bgy\"}[$__range]))",
