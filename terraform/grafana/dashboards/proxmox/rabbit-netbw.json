      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        },
        "overrides": []
      }
