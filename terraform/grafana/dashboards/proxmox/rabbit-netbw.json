      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 7,
      "title": "Inbound / Outbound Rate (physical interfaces)",
      "type": "timeseries",
      "datasource": {
        "uid": "grafanacloud-prom",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{site=\"bgy\"}[1h])",
          "legendFormat": "\u2193 rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{site=\"bgy\"}[1h])",
          "legendFormat": "\u2191 tx {{device}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
