{
  "title": "rabbit-01-psp \u2014 Network Bandwidth",
  "uid": "pve-rabbit-netbw",
  "tags": [
    "proxmox",
    "rabbit",
    "network",
    "bandwidth"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 38,
  "time": {
    "from": "now/M",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Monthly Budget \u2014 rabbit-01-psp",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "% of 25 TB Limit",
      "type": "gauge",
      "datasource": {
        "uid": "grafanacloud-prom",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "(sum(increase(node_network_receive_bytes_total{site=\"bgy\"}[$__range])) + sum(increase(node_network_transmit_bytes_total{site=\"bgy\"}[$__range]))) / 25000000000000.0 * 100",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        },
        "overrides": []
      }
    },
    {
