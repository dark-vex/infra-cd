    {
      "id": 15,
      "title": "Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 16,
      "title": "Pod Logs",
      "type": "logs",
      "datasource": {
        "uid": "grafanacloud-logs",
        "type": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "{cluster=\"kubenuc\",namespace=\"harbor\"}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
