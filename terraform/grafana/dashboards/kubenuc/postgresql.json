      "title": "Running Pods",
      "type": "stat",
      "datasource": {
        "uid": "grafanacloud-prom",
        "type": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
