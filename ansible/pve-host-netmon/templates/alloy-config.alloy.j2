// Grafana Alloy — Proxmox host network monitoring
// Generated by Ansible for {{ inventory_hostname }} ({{ pve_node_label }} site)

// ---------------------------------------------------------------------------
// Network interface byte counters (physical interfaces only)
// ---------------------------------------------------------------------------

prometheus.exporter.unix "netdev" {
  set_collectors = ["netdev"]

  netdev {
    device_exclude = "{{ netmon_device_exclude }}"
  }
}

prometheus.relabel "netdev_instance" {
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]

  // Replace the internal scrape address with the Proxmox hostname
  rule {
    target_label = "instance"
    replacement  = "{{ inventory_hostname }}"
  }
}

prometheus.scrape "netdev" {
  targets         = prometheus.exporter.unix.netdev.targets
  scrape_interval = "{{ netmon_scrape_interval }}"
  forward_to      = [prometheus.relabel.netdev_instance.receiver]
}

// ---------------------------------------------------------------------------
// Remote write to Grafana Cloud
// ---------------------------------------------------------------------------

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = "{{ grafana_prometheus_url }}"

    basic_auth {
      username = "{{ grafana_metrics_username }}"
      password = "{{ grafana_api_key }}"
    }
  }

  external_labels = {
    site = "{{ pve_node_label }}",
  }
}
