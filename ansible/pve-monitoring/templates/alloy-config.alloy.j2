// Grafana Alloy configuration for Proxmox monitoring
// Generated by Ansible for {{ inventory_hostname }} ({{ pve_node_label }} site)

// ---------------------------------------------------------------------------
// PVE target discovery with multi-target relabeling
// ---------------------------------------------------------------------------

discovery.relabel "pve" {
  targets = [
{% for target in pve_targets %}
    {"__address__" = "{{ target }}"},
{% endfor %}
  ]

  // Pass the Proxmox host as the 'target' URL parameter to pve-exporter
  rule {
    source_labels = ["__address__"]
    target_label  = "__param_target"
  }
  // Preserve original host as 'instance' label in metrics
  rule {
    source_labels = ["__param_target"]
    target_label  = "instance"
  }
  // Redirect the actual scrape to the local pve-exporter
  rule {
    target_label = "__address__"
    replacement  = "127.0.0.1:{{ pve_exporter_port }}"
  }
}

prometheus.scrape "pve" {
  targets      = discovery.relabel.pve.output
  metrics_path = "/pve"
  params       = {
    "cluster" = ["1"],
    "node"    = ["1"],
  }
  scrape_interval = "60s"
  forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
}

// ---------------------------------------------------------------------------
// Remote write to Grafana Cloud
// ---------------------------------------------------------------------------

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = "{{ grafana_prometheus_url }}"

    basic_auth {
      username = "{{ grafana_metrics_username }}"
      password = "{{ grafana_api_key }}"
    }
  }

  external_labels = {
    site = "{{ pve_node_label }}",
  }
}
