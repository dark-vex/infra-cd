[Unit]
Description=SeaweedFS volume server
After=network-online.target seaweedfs-master.service
Wants=network-online.target

[Service]
Type=simple
User={{ seaweedfs_user }}
Group={{ seaweedfs_group }}
ExecStart=/usr/local/bin/weed volume \
  -dir={{ seaweedfs_volume_dir }} \
  -ip={{ seaweedfs_ip }} \
  -ip.bind=0.0.0.0 \
  -port={{ seaweedfs_volume_port }} \
  -mserver={% for host in groups['seaweedfs'] %}{{ hostvars[host].seaweedfs_ip }}:{{ seaweedfs_master_port }}{% if not loop.last %},{% endif %}{% endfor %} \
  -dataCenter={{ seaweedfs_data_center }} \
  -rack={{ seaweedfs_rack }} \
  -max={{ seaweedfs_volume_max }}
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
