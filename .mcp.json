{
  "mcpServers": {
    "graylog": {
      "type": "http",
      "url": "http://127.0.0.1:19000/api/mcp",
      "headers": {
        "Authorization": "Bearer ${GRAYLOG_MCP_TOKEN}"
      }
    },
    "grafana": {
      "type": "stdio",
      "command": "mcp-grafana",
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_API_KEY": "${GRAFANA_API_KEY}"
      }
    },
    "netbox": {
      "type": "stdio",
      "command": "uvx",
      "args": ["netbox-mcp-server"],
      "env": {
        "NETBOX_URL": "${NETBOX_URL}",
        "NETBOX_TOKEN": "${NETBOX_TOKEN}"
      }
    }
  }
}
